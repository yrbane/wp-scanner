{
  "version": "1.0.0",
  "updated": "2026-04-10",
  "uploads_safe_dirs": ["cache", "wflogs", "wp-file-manager-pro"],
  "patterns": [
    {
      "name": "eval_base64",
      "pattern": "eval\\s*\\(\\s*base64_decode\\s*\\(",
      "severity": "critical",
      "description": "eval(base64_decode()) — classic PHP backdoor obfuscation"
    },
    {
      "name": "eval_gzinflate",
      "pattern": "eval\\s*\\(\\s*gzinflate\\s*\\(",
      "severity": "critical",
      "description": "eval(gzinflate()) — compressed code execution"
    },
    {
      "name": "eval_gzuncompress",
      "pattern": "eval\\s*\\(\\s*gzuncompress\\s*\\(",
      "severity": "critical",
      "description": "eval(gzuncompress()) — compressed code execution"
    },
    {
      "name": "eval_str_rot13",
      "pattern": "eval\\s*\\(\\s*str_rot13\\s*\\(",
      "severity": "critical",
      "description": "eval(str_rot13()) — ROT13 obfuscation"
    },
    {
      "name": "assert_base64",
      "pattern": "assert\\s*\\(\\s*base64_decode\\s*\\(",
      "severity": "critical",
      "description": "assert(base64_decode()) — alternative to eval backdoor"
    },
    {
      "name": "preg_replace_eval",
      "pattern": "preg_replace\\s*\\(\\s*['\"]/.+/[a-z]*e",
      "severity": "critical",
      "description": "preg_replace with /e modifier — code execution via regex"
    },
    {
      "name": "webshell_signature",
      "pattern": "(?i)(c99shell|r57shell|WSO\\s+\\d|b374k|FilesMan|WebShell)",
      "severity": "critical",
      "description": "Known webshell signatures (c99, r57, WSO, b374k, FilesMan)"
    },
    {
      "name": "suppressed_superglobal_exec",
      "pattern": "@\\$_(GET|POST|REQUEST|COOKIE)\\s*\\[",
      "severity": "critical",
      "description": "Suppressed superglobal access — common webshell pattern"
    },
    {
      "name": "create_function_user_input",
      "pattern": "create_function\\s*\\(.*\\$_(GET|POST|REQUEST)",
      "severity": "critical",
      "description": "create_function() with user input — dynamic code execution"
    },
    {
      "name": "shell_exec",
      "pattern": "\\bshell_exec\\s*\\(",
      "severity": "warning",
      "description": "shell_exec() — shell command execution"
    },
    {
      "name": "system_call",
      "pattern": "\\bsystem\\s*\\(",
      "severity": "warning",
      "description": "system() — shell command execution"
    },
    {
      "name": "passthru_call",
      "pattern": "\\bpassthru\\s*\\(",
      "severity": "warning",
      "description": "passthru() — shell command execution with output"
    },
    {
      "name": "exec_call",
      "pattern": "\\bexec\\s*\\(",
      "severity": "warning",
      "description": "exec() — shell command execution"
    },
    {
      "name": "popen_call",
      "pattern": "\\bpopen\\s*\\(",
      "severity": "warning",
      "description": "popen() — process opening"
    },
    {
      "name": "proc_open_call",
      "pattern": "\\bproc_open\\s*\\(",
      "severity": "warning",
      "description": "proc_open() — process opening with I/O control"
    },
    {
      "name": "file_put_contents_user_input",
      "pattern": "file_put_contents\\s*\\(.*\\$_(GET|POST|REQUEST)",
      "severity": "warning",
      "description": "file_put_contents() with user input — arbitrary file write"
    },
    {
      "name": "base64_decode_user_input",
      "pattern": "base64_decode\\s*\\(.*\\$_(GET|POST|REQUEST|COOKIE)",
      "severity": "warning",
      "description": "base64_decode() with superglobal — encoded payload execution"
    },
    {
      "name": "hex_obfuscation",
      "pattern": "(\\\\x[0-9a-fA-F]{2}){10,}",
      "severity": "warning",
      "description": "Hex-encoded string obfuscation (10+ sequences)"
    },
    {
      "name": "chr_obfuscation",
      "pattern": "(chr\\s*\\(\\s*\\d+\\s*\\)\\s*\\.?\\s*){10,}",
      "severity": "warning",
      "description": "chr() chain obfuscation (10+ calls)"
    },
    {
      "name": "eval_variable",
      "pattern": "\\beval\\s*\\(\\s*\\$",
      "severity": "info",
      "description": "eval() with variable — may be legitimate but worth checking"
    }
  ]
}
